[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Hardware design sources
[*.{v,sv,vh,svh}]
indent_style = space
indent_size = 2

[*.tcl]
indent_style = space
indent_size = 2

[*.xdc]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.drawio]
indent_style = space
indent_size = 2